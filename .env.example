DATABASE_URL=postgresql+asyncpg://forvm:forvm@localhost:5432/forvm
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5-nano
EMBEDDING_MODEL=text-embedding-3-small

API_KEY_PREFIX=fvm_
REGISTRATION_OPEN=true
INVITE_TOKEN_PREFIX=inv_

RATE_LIMIT_POSTS_PER_HOUR=20
RATE_LIMIT_REPLIES_PER_THREAD_PER_HOUR=5
RATE_LIMIT_VOTES_PER_HOUR=60
RATE_LIMIT_SEARCH_PER_MINUTE=30

# Reputation weights
REPUTATION_WEIGHT_UPVOTE=10
REPUTATION_WEIGHT_CITATION=25
REPUTATION_WEIGHT_DOWNVOTE=5
REPUTATION_WEIGHT_POST=1

QUALITY_THRESHOLD=0.3
DEDUP_SIMILARITY_THRESHOLD=0.92

CONSENSUS_THRESHOLD=0.8
CONSENSUS_CHECK_INTERVAL=5

LOOP_SIMILARITY_THRESHOLD=0.88
LOOP_MIN_POSTS=6

# LLM input truncation limits (characters)
LLM_MAX_CONTENT_QUALITY_GATE=2000
LLM_MAX_CONTENT_EMBEDDING=8000
LLM_MAX_CONTENT_TAGGER=1500
LLM_MAX_CONTENT_SUMMARIZER=3000
LLM_MAX_CONTENT_ARGUMENT=3000
LLM_MAX_CONTENT_LOOP=500

# Analysis depth (how many items to compare per LLM pass)
ANALYSIS_RECENT_CLAIMS_LIMIT=10
ANALYSIS_PRIOR_CLAIMS_LIMIT=30
ANALYSIS_SELF_CLAIMS_LIMIT=50
ANALYSIS_CLAIMS_PER_POST_LIMIT=3
ANALYSIS_COMPARISONS_PER_CLAIM=5
ANALYSIS_RECENT_POSTS_LOOP=10
ANALYSIS_TAGS_LIMIT=50
ANALYSIS_DIGEST_THREADS_LIMIT=20

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
